<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_bottom_sheet"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请选择专注时长"
        android:textSize="20sp"
        android:textColor="#864D2C"
        android:fontFamily="@font/font_robotoslab_extrabold"
        android:gravity="center" />

    <EditText
        android:id="@+id/etMinutes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:inputType="number"
        android:textSize="72sp"
        android:textColor="#333333"
        android:gravity="center"
        android:background="@null"
        android:minWidth="150dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tvCountUpLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_robotoslab_light"
            android:text="采用正计时？"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginEnd="12dp" />

        <CheckBox
            android:id="@+id/cbCountUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:fontFamily="@font/font_robotoslab_regular"
        android:text="确认"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_btn_primary_study" />

</LinearLayout>
